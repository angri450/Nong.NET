<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId Condition="'$(PackageId)' == ''">Angri450.Nong.OcrRuntime.WinX64</PackageId>
    <Version>3.2.5</Version>
    <Authors>angri450</Authors>
    <Description>Nong PP-OCRv5 native runtime bundle for one platform. Contains PaddleInference and OpenCvSharp native DLL/SO/DYLIB files only; no Python and no executable OCR wrapper.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/angri450/Nong.NET</RepositoryUrl>
    <PackageTags>nong ocr paddleocr ppocrv5 native-runtime paddle-inference opencv</PackageTags>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoBuild>true</NoBuild>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <UpstreamPaddlePackage Condition="'$(UpstreamPaddlePackage)' == ''">Sdcb.PaddleInference.runtime.win64.mkl</UpstreamPaddlePackage>
    <UpstreamPaddleVersion Condition="'$(UpstreamPaddleVersion)' == ''">3.3.1.70</UpstreamPaddleVersion>
    <UpstreamPaddleNativePrefix Condition="'$(UpstreamPaddleNativePrefix)' == ''">runtimes/win-x64/native</UpstreamPaddleNativePrefix>
    <UpstreamOpenCvPackage Condition="'$(UpstreamOpenCvPackage)' == ''">OpenCvSharp4.runtime.win</UpstreamOpenCvPackage>
    <UpstreamOpenCvVersion Condition="'$(UpstreamOpenCvVersion)' == ''">4.11.0.20250507</UpstreamOpenCvVersion>
    <UpstreamOpenCvNativePrefix Condition="'$(UpstreamOpenCvNativePrefix)' == ''">runtimes/win-x64/native</UpstreamOpenCvNativePrefix>
    <NuGetPackageRoot Condition="'$(NuGetPackageRoot)' == ''">$(UserProfile)\.nuget\packages</NuGetPackageRoot>
  </PropertyGroup>

  <PropertyGroup>
    <PaddleRoot>$(NuGetPackageRoot)\$([System.String]::Copy('$(UpstreamPaddlePackage)').ToLowerInvariant())\$(UpstreamPaddleVersion)</PaddleRoot>
    <OpenCvRoot>$(NuGetPackageRoot)\$([System.String]::Copy('$(UpstreamOpenCvPackage)').ToLowerInvariant())\$(UpstreamOpenCvVersion)</OpenCvRoot>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="$(PaddleRoot)\$(UpstreamPaddleNativePrefix)\**\*.*"
          Pack="true"
          PackagePath="runtimes/$(RuntimeIdentifier)/native/%(RecursiveDir)%(Filename)%(Extension)" />
    <None Include="$(OpenCvRoot)\$(UpstreamOpenCvNativePrefix)\**\*.*"
          Pack="true"
          PackagePath="runtimes/$(RuntimeIdentifier)/native/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <Target Name="ValidateRuntimeInputs" BeforeTargets="Pack">
    <Error Condition="!Exists('$(PaddleRoot)\$(UpstreamPaddleNativePrefix)')"
           Text="Paddle native runtime package is missing from NuGet cache: $(PaddleRoot)\$(UpstreamPaddleNativePrefix). Restore $(UpstreamPaddlePackage) $(UpstreamPaddleVersion) first." />
    <Error Condition="!Exists('$(OpenCvRoot)\$(UpstreamOpenCvNativePrefix)')"
           Text="OpenCvSharp native runtime package is missing from NuGet cache: $(OpenCvRoot)\$(UpstreamOpenCvNativePrefix). Restore $(UpstreamOpenCvPackage) $(UpstreamOpenCvVersion) first." />
  </Target>
</Project>
