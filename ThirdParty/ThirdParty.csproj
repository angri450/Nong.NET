<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>ThirdParty</RootNamespace>
    <AssemblyName>Angri450.Nong.ThirdParty</AssemblyName>
    <PackageId>Angri450.Nong.ThirdParty</PackageId>
    <Version>4.0.0</Version>
    <Authors>angri450</Authors>
    <Description>Merged source of ClosedXML, DocumentFormat.OpenXml, ScottPlot, MSAGL, SkiaSharp, HarfBuzzSharp, SixLabors.Fonts, ZXing.Net, PdfPig and sub-dependencies — compiled into a single assembly. Low-external-dependency foundation for the Angri450.Nong document toolkit.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/angri450/Nong.NET</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>closedxml openxml scottplot msagl skiasharp harfbuzz zxing pdfpig barcode qr pdf excel chart diagram document-generation</PackageTags>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <LangVersion>12</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsTrimmable>true</IsTrimmable>
    <NoWarn>$(NoWarn);CS1591;CS1570;CS1572;CS1573;CS1574;CS1587;CS1712;CS8600;CS8601;CS8602;CS8603;CS8604;CS8618;CS8625;CS8765;CS8767;CS8769;CS0618;CS0612;CS0168;CS0219;CS0414;CS0162;CS1998;CS1584;NU1605;IL2050</NoWarn>
    <DefineConstants>$(DefineConstants);USE_LIBRARY_IMPORT</DefineConstants>
    <!-- OpenXml source generator flags -->
    <DocumentFormat_OpenXml_Generator_NamespaceLookup>true</DocumentFormat_OpenXml_Generator_NamespaceLookup>
    <DocumentFormat_OpenXml_Generator_Parts>true</DocumentFormat_OpenXml_Generator_Parts>
    <DocumentFormat_OpenXml_Generator_Schemas>true</DocumentFormat_OpenXml_Generator_Schemas>
    <DocumentFormat_OpenXml_Generator_Factories>true</DocumentFormat_OpenXml_Generator_Factories>
  </PropertyGroup>

  <!-- ===== Source files from all third-party libraries ===== -->

  <!-- Specific common/ shim files needed by OpenXml (not polyfills) -->
  <ItemGroup>
    <Compile Include="..\common\System\EnumExtensions.cs" Link="Shims\EnumExtensions.cs" />
    <Compile Include="..\common\System\IO\StreamReadExtensions.cs" Link="Shims\StreamReadExtensions.cs" />
  </ItemGroup>

  <!-- SkiaSharp / HarfBuzzSharp shared bindings — exclude original with conditional namespace and polyfills -->
  <ItemGroup>
    <Compile Include="..\Binding.Shared\**\*.cs" Exclude="..\Binding.Shared\DelegateProxies.shared.cs;..\Binding.Shared\HashCode.cs" Link="Binding.Shared\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- UnicodeTrieGenerator (used by SixLabors.Fonts — only 3 specific files) -->
  <ItemGroup>
    <Compile Include="..\UnicodeTrieGenerator\StateAutomation\StateMachine.cs" Link="Unicode\StateAutomation\StateMachine.cs" />
    <Compile Include="..\UnicodeTrieGenerator\StateAutomation\INode.cs" Link="Unicode\StateAutomation\INode.cs" />
    <Compile Include="..\UnicodeTrieGenerator\StateAutomation\SymbolTable.cs" Link="Unicode\StateAutomation\SymbolTable.cs" />
  </ItemGroup>

  <!-- SixLabors.Fonts shared infrastructure -->
  <ItemGroup>
    <Compile Include="..\SixLabors.Fonts\shared-infrastructure\src\SharedInfrastructure\*.cs" Link="SharedInfrastructure\%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Main third-party libraries (exclude bin/obj/common polyfills) -->
  <ItemGroup>
    <Compile Include="..\ClosedXML\**\*.cs" Exclude="..\ClosedXML\bin\**\*;..\ClosedXML\obj\**\*" />
    <Compile Include="..\ClosedXML.IO\**\*.cs" Exclude="..\ClosedXML.IO\bin\**\*;..\ClosedXML.IO\obj\**\*" />
    <Compile Include="..\ClosedXML.Parser\**\*.cs" Exclude="..\ClosedXML.Parser\bin\**\*;..\ClosedXML.Parser\obj\**\*" />
    <Compile Include="..\DocumentFormat.OpenXml\**\*.cs" Exclude="..\DocumentFormat.OpenXml\bin\**\*;..\DocumentFormat.OpenXml\obj\**\*;..\DocumentFormat.OpenXml\common\**\*" />
    <Compile Include="..\DocumentFormat.OpenXml.Framework\**\*.cs" Exclude="..\DocumentFormat.OpenXml.Framework\bin\**\*;..\DocumentFormat.OpenXml.Framework\obj\**\*" />
    <Compile Include="..\ExcelNumberFormat\**\*.cs" Exclude="..\ExcelNumberFormat\bin\**\*;..\ExcelNumberFormat\obj\**\*" />
    <Compile Include="..\HarfBuzzSharp\**\*.cs" Exclude="..\HarfBuzzSharp\bin\**\*;..\HarfBuzzSharp\obj\**\*" />
    <Compile Include="..\MSAGL\**\*.cs" Exclude="..\MSAGL\bin\**\*;..\MSAGL\obj\**\*" />
    <Compile Include="..\MSAGL.Drawing\**\*.cs" Exclude="..\MSAGL.Drawing\bin\**\*;..\MSAGL.Drawing\obj\**\*" />
    <Compile Include="..\RBush\**\*.cs" Exclude="..\RBush\bin\**\*;..\RBush\obj\**\*" />
    <Compile Include="..\ScottPlot\**\*.cs" Exclude="..\ScottPlot\bin\**\*;..\ScottPlot\obj\**\*;..\ScottPlot\Testing\**\*;..\ScottPlot\Statistics\Tests\**\*" />
    <Compile Include="..\SixLabors.Fonts\**\*.cs" Exclude="..\SixLabors.Fonts\bin\**\*;..\SixLabors.Fonts\obj\**\*;..\SixLabors.Fonts\shared-infrastructure\**\*" />
    <Compile Include="..\SkiaSharp\**\*.cs" Exclude="..\SkiaSharp\bin\**\*;..\SkiaSharp\obj\**\*" />
    <Compile Include="..\SkiaSharp.HarfBuzz\**\*.cs" Exclude="..\SkiaSharp.HarfBuzz\bin\**\*;..\SkiaSharp.HarfBuzz\obj\**\*" />
    <Compile Include="..\ClippitPowerTools\**\*.cs" Exclude="..\ClippitPowerTools\bin\**\*;..\ClippitPowerTools\obj\**\*;..\ClippitPowerTools\Excel\**\*;..\ClippitPowerTools\PowerPoint\**\*;..\ClippitPowerTools\Html\**\*;..\ClippitPowerTools\Internal\**\*;..\ClippitPowerTools\MetricsGetter.cs" />
    <Compile Include="..\ShapeCrawler\**\*.cs" Exclude="..\ShapeCrawler\bin\**\*;..\ShapeCrawler\obj\**\*;..\ShapeCrawler\Slides\XmlPicture.cs" />
  </ItemGroup>

  <!-- ZXing.Net QR decode source subset: no platform bindings, writers, renderers, demos or tests -->
  <ItemGroup>
    <Compile Include="..\ZXing.Net\BarcodeFormat.cs" />
    <Compile Include="..\ZXing.Net\BaseLuminanceSource.cs" />
    <Compile Include="..\ZXing.Net\Binarizer.cs" />
    <Compile Include="..\ZXing.Net\BinaryBitmap.cs" />
    <Compile Include="..\ZXing.Net\DecodeHintType.cs" />
    <Compile Include="..\ZXing.Net\FormatException.cs" />
    <Compile Include="..\ZXing.Net\InvertedLuminanceSource.cs" />
    <Compile Include="..\ZXing.Net\LuminanceSource.cs" />
    <Compile Include="..\ZXing.Net\Reader.cs" />
    <Compile Include="..\ZXing.Net\ReaderException.cs" />
    <Compile Include="..\ZXing.Net\Result.cs" />
    <Compile Include="..\ZXing.Net\ResultMetadataType.cs" />
    <Compile Include="..\ZXing.Net\ResultPoint.cs" />
    <Compile Include="..\ZXing.Net\ResultPointCallback.cs" />
    <Compile Include="..\ZXing.Net\RGBLuminanceSource.cs" />
    <Compile Include="..\ZXing.Net\SupportClass.cs" />
    <Compile Include="..\ZXing.Net\common\BitArray.cs" />
    <Compile Include="..\ZXing.Net\common\BitMatrix.cs" />
    <Compile Include="..\ZXing.Net\common\BitSource.cs" />
    <Compile Include="..\ZXing.Net\common\CharacterSetECI.cs" />
    <Compile Include="..\ZXing.Net\common\DecoderResult.cs" />
    <Compile Include="..\ZXing.Net\common\DefaultGridSampler.cs" />
    <Compile Include="..\ZXing.Net\common\DetectorResult.cs" />
    <Compile Include="..\ZXing.Net\common\ECI.cs" />
    <Compile Include="..\ZXing.Net\common\GridSampler.cs" />
    <Compile Include="..\ZXing.Net\common\HybridBinarizer.cs" />
    <Compile Include="..\ZXing.Net\common\GlobalHistogramBinarizer.cs" />
    <Compile Include="..\ZXing.Net\common\PerspectiveTransform.cs" />
    <Compile Include="..\ZXing.Net\common\StringUtils.cs" />
    <Compile Include="..\ZXing.Net\common\detector\MathUtils.cs" />
    <Compile Include="..\ZXing.Net\common\detector\WhiteRectangleDetector.cs" />
    <Compile Include="..\ZXing.Net\common\reedsolomon\GenericGF.cs" />
    <Compile Include="..\ZXing.Net\common\reedsolomon\GenericGFPoly.cs" />
    <Compile Include="..\ZXing.Net\common\reedsolomon\ReedSolomonDecoder.cs" />
    <Compile Include="..\ZXing.Net\qrcode\QRCodeReader.cs" />
    <Compile Include="..\ZXing.Net\qrcode\decoder\**\*.cs" />
    <Compile Include="..\ZXing.Net\qrcode\detector\**\*.cs" />
  </ItemGroup>

  <!-- PdfPig source: pure .NET PDF parser/writer without tests, examples or tools -->
  <ItemGroup>
    <Compile Include="..\PdfPig\src\UglyToad.PdfPig\**\*.cs" Exclude="..\PdfPig\src\UglyToad.PdfPig\bin\**\*;..\PdfPig\src\UglyToad.PdfPig\obj\**\*" />
    <Compile Include="..\PdfPig\src\UglyToad.PdfPig.Core\**\*.cs" Exclude="..\PdfPig\src\UglyToad.PdfPig.Core\bin\**\*;..\PdfPig\src\UglyToad.PdfPig.Core\obj\**\*" />
    <Compile Include="..\PdfPig\src\UglyToad.PdfPig.Fonts\**\*.cs" Exclude="..\PdfPig\src\UglyToad.PdfPig.Fonts\bin\**\*;..\PdfPig\src\UglyToad.PdfPig.Fonts\obj\**\*" />
    <Compile Include="..\PdfPig\src\UglyToad.PdfPig.Tokenization\**\*.cs" Exclude="..\PdfPig\src\UglyToad.PdfPig.Tokenization\bin\**\*;..\PdfPig\src\UglyToad.PdfPig.Tokenization\obj\**\*" />
    <Compile Include="..\PdfPig\src\UglyToad.PdfPig.Tokens\**\*.cs" Exclude="..\PdfPig\src\UglyToad.PdfPig.Tokens\bin\**\*;..\PdfPig\src\UglyToad.PdfPig.Tokens\obj\**\*" />
  </ItemGroup>

  <!-- Remove conflicting files (assembly attributes, type forwards, polyfills) -->
  <ItemGroup>
    <Compile Remove="..\**\AssemblyInfo.cs" />
    <Compile Remove="..\**\*AssemblyInfo.cs" />
    <Compile Remove="..\DocumentFormat.OpenXml\TypeForwards.cs" />
    <Compile Remove="..\DocumentFormat.OpenXml.Framework\Properties\Properties.cs" />
    <Compile Remove="..\ScottPlot\Usings.cs" />
    <Compile Remove="..\ScottPlot\**\CompilerServices.cs" />
    <Compile Remove="..\ClosedXML\Properties\**\*" />
    <Compile Remove="..\MSAGL.Drawing\AssemblyInfo.cs" />
    <Compile Remove="..\MSAGL\AssemblyInfo.cs" />
    <Compile Remove="..\HarfBuzzSharp\DelegateProxies.cs" />
    <Compile Remove="..\ClippitPowerTools\Properties\**\*" />
    <Compile Remove="..\ShapeCrawler\Properties\**\*" />
    <Compile Remove="..\PdfPig\src\UglyToad.PdfPig.Fonts\Util\StringExtensions.cs" />
  </ItemGroup>

  <!-- OpenXml Source Generator infrastructure (borrowed from OpenXmlSourceGenerator.targets) -->
  <Import Project="..\data\OpenXmlData.targets" />

  <ItemGroup>
    <ProjectReference Include="..\DocumentFormat.OpenXml.Generator\DocumentFormat.OpenXml.Generator.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true" GlobalPropertiesToRemove="TargetFramework" />
    <ProjectReference Include="..\DocumentFormat.OpenXml.Generator.Models\DocumentFormat.OpenXml.Generator.Models.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true" GlobalPropertiesToRemove="TargetFramework" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="@(OpenXmlDataNamespace)" OpenXml="Namespace" LinkBase="data" />
    <AdditionalFiles Include="@(OpenXmlDataSchematron)" OpenXml="Schematron" LinkBase="data" />
    <AdditionalFiles Include="@(OpenXmlDataPart)" OpenXml="Part" LinkBase="data/parts" />
    <AdditionalFiles Include="@(OpenXmlDataSchema)" OpenXml="Schema" LinkBase="data/schema" />
    <AdditionalFiles Include="@(OpenXmlDataTypedNamespace)" OpenXml="TypedNamespace" LinkBase="data/typed" />
    <AdditionalFiles Include="@(OpenXmlDataTypedSchema)" OpenXml="TypedSchema" LinkBase="data/typed" />
  </ItemGroup>

  <ItemGroup>
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="OpenXml" />
    <CompilerVisibleProperty Include="DocumentFormat_OpenXml_Generator_NamespaceLookup" />
    <CompilerVisibleProperty Include="DocumentFormat_OpenXml_Generator_Parts" />
    <CompilerVisibleProperty Include="DocumentFormat_OpenXml_Generator_Schemas" />
    <CompilerVisibleProperty Include="DocumentFormat_OpenXml_Generator_Factories" />
    <CompilerVisibleProperty Include="DocumentFormat_OpenXml_Generator_Linq" />
  </ItemGroup>

  <!-- Embedded resources (LogicalName must match ClosedXML hardcoded paths) -->
  <ItemGroup>
    <EmbeddedResource Include="..\ClosedXML\Graphics\Fonts\CarlitoBare-Bold.ttf">
      <LogicalName>ClosedXML.Graphics.Fonts.CarlitoBare-Bold.ttf</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\ClosedXML\Graphics\Fonts\CarlitoBare-BoldItalic.ttf">
      <LogicalName>ClosedXML.Graphics.Fonts.CarlitoBare-BoldItalic.ttf</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\ClosedXML\Graphics\Fonts\CarlitoBare-Italic.ttf">
      <LogicalName>ClosedXML.Graphics.Fonts.CarlitoBare-Italic.ttf</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\ClosedXML\Graphics\Fonts\CarlitoBare-Regular.ttf">
      <LogicalName>ClosedXML.Graphics.Fonts.CarlitoBare-Regular.ttf</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- OpenXml validation resources (.resx compiled to .resources by SDK) -->
  <ItemGroup>
    <EmbeddedResource Include="..\DocumentFormat.OpenXml.Framework\Resources\ExceptionMessages.resx">
      <CustomToolNamespace>DocumentFormat.OpenXml</CustomToolNamespace>
    </EmbeddedResource>
    <EmbeddedResource Include="..\DocumentFormat.OpenXml.Framework\Validation\ValidationResources.resx">
      <CustomToolNamespace>DocumentFormat.OpenXml.Validation</CustomToolNamespace>
      <LogicalName>DocumentFormat.OpenXml.Validation.ValidationResources.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- PdfPig resources: logical names match upstream resource lookup strings -->
  <ItemGroup>
    <EmbeddedResource Include="..\PdfPig\src\UglyToad.PdfPig\Resources\CMap\*">
      <LogicalName>UglyToad.PdfPig.Resources.CMap.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\PdfPig\src\UglyToad.PdfPig\Resources\ICC\*">
      <LogicalName>UglyToad.PdfPig.Resources.ICC.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\PdfPig\src\UglyToad.PdfPig.Fonts\Resources\AdobeFontMetrics\*">
      <LogicalName>UglyToad.PdfPig.Fonts.Resources.AdobeFontMetrics.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\PdfPig\src\UglyToad.PdfPig.Fonts\Resources\GlyphList\*">
      <LogicalName>UglyToad.PdfPig.Fonts.Resources.GlyphList.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- NuGet dependencies -->
  <ItemGroup>
    <PackageReference Include="System.IO.Packaging" Version="10.0.2" />
    <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="3.119.0" />
    <PackageReference Include="SkiaSharp.NativeAssets.macOS" Version="3.119.0" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux.NoDependencies" Version="3.119.0" />
    <PackageReference Include="HarfBuzzSharp.NativeAssets.Win32" Version="8.3.1.1" />
    <PackageReference Include="HarfBuzzSharp.NativeAssets.macOS" Version="8.3.1.1" />
    <PackageReference Include="HarfBuzzSharp.NativeAssets.Linux" Version="8.3.1.1" />
    <PackageReference Include="System.IO.Hashing" Version="9.0.0" />
    <PackageReference Include="System.Resources.Extensions" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="..\PdfPig\LICENSE" Pack="true" PackagePath="third-party/pdfpig/" />
    <None Include="..\PdfPig\NOTICES.txt" Pack="true" PackagePath="third-party/pdfpig/" />
  </ItemGroup>

</Project>
